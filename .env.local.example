# Google Calendar API - Booking Integration
#
# SETUP STEPS:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable "Google Calendar API" in APIs & Services > Library
# 4. Go to APIs & Services > Credentials > Create Credentials > Service Account
# 5. Give it a name (e.g. "fie-booking") and click Create
# 6. Skip optional permissions, click Done
# 7. Click on the service account > Keys tab > Add Key > JSON
# 8. Download the JSON file — this is your service account key
# 9. Copy the ENTIRE contents of that JSON file and paste it below (as a single line)
# 10. Go to Google Calendar > Settings > Share with specific people
# 11. Add the service account email (e.g. fie-booking@project-id.iam.gserviceaccount.com)
# 12. Give it "Make changes to events" permission
#
# GOOGLE_SERVICE_ACCOUNT_KEY = the entire JSON key file contents (as a single line)
# GOOGLE_CALENDAR_ID = the Gmail address of the calendar owner (e.g. client@gmail.com)

GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
GOOGLE_CALENDAR_ID=client-email@gmail.com
